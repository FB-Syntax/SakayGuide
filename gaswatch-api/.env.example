# Network port used by the HTTP server.
PORT=3000

# Supported values: development, test, production.
NODE_ENV=development

# A comma-separated allowlist of browser origins, or * to allow all origins.
CORS_ORIGIN=*

# Maximum accepted JSON or URL-encoded request-body size.
JSON_BODY_LIMIT=1mb

# Maximum time to wait for open requests during graceful shutdown, in milliseconds.
SHUTDOWN_TIMEOUT_MS=10000
